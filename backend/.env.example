# ============================================
# BREME - Variables d'environnement
# COPIER ce fichier en .env et remplir les valeurs
# NE JAMAIS COMMITTER .env sur GitHub !
# ============================================

# Serveur
PORT=5000
NODE_ENV=development

# Base de données PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=breme_db
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_db

# JWT Secret (changer par une chaîne aléatoire longue)
JWT_SECRET=breme_super_secret_jwt_key_changez_ceci_en_production
JWT_EXPIRES_IN=30d

# Email (pour vérification email + notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=votre@email.com
EMAIL_PASS=votre_app_password_gmail

# ============================================
# PAIEMENTS - À remplir après création des comptes
# ============================================

# PayDunya (Orange Money + MTN MoMo Cameroun)
# Créer un compte sur : https://paydunya.com
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test   # changer en "live" pour la production

# NOWPayments (Crypto : USDT, ETH, BTC)
# Créer un compte sur : https://nowpayments.io
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Orange Money direct (si tu utilises l'API officielle)
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=

# Numéro Orange Money pour paiement manuel
OM_PHONE_NUMBER=+237699959921
OM_ACCOUNT_NAME=BREME

# Abonnement
SUBSCRIPTION_PRICE_FCFA=10000
SUBSCRIPTION_DURATION_DAYS=30
